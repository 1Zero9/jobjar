generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MemberRole {
  admin
  power_user
  member
  viewer
}

enum RecurrenceType {
  daily
  weekly
  monthly
  custom
}

enum OccurrenceStatus {
  pending
  done
  skipped
  overdue
}

enum LogAction {
  started
  completed
  skipped
  reopened
  task_created
  task_updated
  task_deleted
  assignee_changed
}

enum ShareScope {
  public_dashboard
  room_view
}

enum JobKind {
  upkeep
  issue
  project
  clear_out
  outdoor
  planning
}

enum CaptureStage {
  captured
  shaped
  active
  done
}

model User {
  id              String             @id @default(uuid()) @db.Uuid
  email           String             @unique
  displayName     String
  createdAt       DateTime           @default(now())
  authCredential  AuthCredential?
  ownedHouseholds Household[]        @relation("HouseholdOwner")
  memberships     HouseholdMember[]
  loggedTasks      Task[]            @relation("TaskLogger")
  completions     TaskOccurrence[]   @relation("OccurrenceCompleter")
  assignments     TaskAssignment[]
}

model AuthCredential {
  userId       String   @id @db.Uuid
  passwordHash String
  updatedAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Household {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  timezone    String            @default("Europe/Dublin")
  ownerUserId String            @db.Uuid
  createdAt   DateTime          @default(now())
  owner       User              @relation("HouseholdOwner", fields: [ownerUserId], references: [id])
  members     HouseholdMember[]
  locations   Location[]
  rooms       Room[]
  shareLinks  ShareLink[]
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  householdId String   @db.Uuid
  name        String
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  household   Household                @relation(fields: [householdId], references: [id], onDelete: Cascade)
  rooms       Room[]
  memberAccess HouseholdMemberLocationAccess[]

  @@index([householdId])
}

model HouseholdMember {
  householdId String    @db.Uuid
  userId      String    @db.Uuid
  role        MemberRole
  joinedAt    DateTime  @default(now())
  household   Household                     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationAccess HouseholdMemberLocationAccess[]

  @@id([householdId, userId])
}

model HouseholdMemberLocationAccess {
  householdId String   @db.Uuid
  userId      String   @db.Uuid
  locationId  String   @db.Uuid
  createdAt   DateTime @default(now())
  member      HouseholdMember @relation(fields: [householdId, userId], references: [householdId, userId], onDelete: Cascade)
  location    Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([householdId, userId, locationId])
  @@index([locationId])
}

model Room {
  id          String    @id @default(uuid()) @db.Uuid
  householdId String    @db.Uuid
  locationId  String?   @db.Uuid
  name        String
  designation String
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@index([householdId])
  @@index([locationId])
}

model Task {
  id               String           @id @default(uuid()) @db.Uuid
  roomId           String           @db.Uuid
  createdByUserId  String?          @db.Uuid
  title            String
  description      String?
  detailNotes      String?
  locationDetails  String?
  jobKind          JobKind          @default(upkeep)
  captureStage     CaptureStage     @default(captured)
  projectParentId  String?          @db.Uuid
  priority         Int              @default(3)
  estimatedMinutes Int              @default(15)
  projectTargetAt  DateTime?
  projectBudgetCents Int?
  graceHours       Int              @default(12)
  validationMode   String           @default("basic")
  minimumMinutes   Int              @default(0)
  active           Boolean          @default(true)
  isPrivate        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  room             Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  logger           User?            @relation("TaskLogger", fields: [createdByUserId], references: [id], onDelete: SetNull)
  schedule         TaskSchedule?
  occurrences      TaskOccurrence[]
  logs             TaskLog[]
  assignments      TaskAssignment[]
  projectCosts     ProjectCost[]
  projectMaterials ProjectMaterial[]
  projectMilestones ProjectMilestone[]
  projectParent    Task?            @relation("TaskProjectChildren", fields: [projectParentId], references: [id], onDelete: SetNull)
  projectChildren  Task[]           @relation("TaskProjectChildren")

  @@index([roomId])
  @@index([roomId, active])
  @@index([createdByUserId])
  @@index([projectParentId])
}

model TaskSchedule {
  id             String         @id @default(uuid()) @db.Uuid
  taskId         String         @unique @db.Uuid
  recurrenceType RecurrenceType
  intervalCount  Int            @default(1)
  daysOfWeek     Int[]
  dayOfMonth     Int?
  timeOfDay      String?
  nextDueAt      DateTime?
  task           Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskOccurrence {
  id          String           @id @default(uuid()) @db.Uuid
  taskId      String           @db.Uuid
  dueAt       DateTime
  status      OccurrenceStatus @default(pending)
  completedAt DateTime?
  completedBy String?          @db.Uuid
  createdAt   DateTime         @default(now())
  task        Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completer   User?            @relation("OccurrenceCompleter", fields: [completedBy], references: [id])
  logs        TaskLog[]

  @@index([dueAt])
  @@index([taskId])
}

model TaskLog {
  id              String          @id @default(uuid()) @db.Uuid
  taskId          String          @db.Uuid
  occurrenceId    String?         @db.Uuid
  actorUserId     String?         @db.Uuid
  action          LogAction
  atTime          DateTime        @default(now())
  durationSeconds Int?
  note            String?
  task            Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  occurrence      TaskOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
}

model TaskAssignment {
  id           String   @id @default(uuid()) @db.Uuid
  taskId       String   @db.Uuid
  userId       String   @db.Uuid
  assignedFrom DateTime
  assignedTo   DateTime?
  createdAt    DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectCost {
  id          String   @id @default(uuid()) @db.Uuid
  taskId       String   @db.Uuid
  title       String
  amountCents Int
  notedAt     DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model ProjectMaterial {
  id                 String   @id @default(uuid()) @db.Uuid
  taskId             String   @db.Uuid
  title              String
  quantityLabel      String?
  source             String?
  estimatedCostCents Int?
  actualCostCents    Int?
  purchasedAt        DateTime?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model ProjectMilestone {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String   @db.Uuid
  title       String
  targetAt    DateTime?
  completedAt DateTime?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model ShareLink {
  id          String    @id @default(uuid()) @db.Uuid
  householdId String    @db.Uuid
  slug        String    @unique
  scope       ShareScope
  expiresAt   DateTime?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}
