# Vercel Postgres or any Postgres connection URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Optional: use the non-pooled direct connection for migrations when available.
# On Vercel Postgres this is usually POSTGRES_URL_NON_POOLING.
# If omitted, scripts fall back to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Required in production: signs session cookies. Generate with: openssl rand -hex 32
# If not set, the server will refuse to start in production.
SESSION_SIGNING_SECRET="replace-with-a-strong-random-secret"

# Legacy fallback passcode used only for accounts without a stored passcode hash.
# Set to something strong — users without a stored password hash will authenticate with this.
HOUSEHOLD_PASSCODE="change-me"
