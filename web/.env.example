# Vercel Postgres or any Postgres connection URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Use the non-pooled direct connection for migrations when available.
# On Vercel Postgres this is usually POSTGRES_URL_NON_POOLING.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Shared household passcode used on /login
HOUSEHOLD_PASSCODE="jobjar"
